# Application
APP_NAME=OneIT
APP_ENV=development
DEBUG=true

# Database
POSTGRES_USER=oneit
POSTGRES_PASSWORD=oneit_secret
POSTGRES_DB=oneit
DATABASE_URL=postgresql://oneit:oneit_secret@postgres:5432/oneit

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# SAML (optional)
SAML_METADATA_URL=
SAML_ENTITY_ID=
SAML_ACS_URL=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@oneit.local

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
